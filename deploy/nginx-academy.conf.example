# Example Nginx server block — adjust server_name, SSL paths, and upstream port.
# Place in /etc/nginx/sites-available/ and symlink to sites-enabled.

upstream academy_nextjs {
    server 127.0.0.1:3000;
    keepalive 64;
}

server {
    listen 80;
    listen [::]:80;
    server_name academy.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name academy.example.com;

    # ssl_certificate /etc/letsencrypt/live/academy.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/academy.example.com/privkey.pem;

    client_max_body_size 10M;

    location / {
        proxy_pass http://academy_nextjs;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_cache_bypass $http_upgrade;
    }

    # Stripe webhooks need the raw body — do not add a separate location that buffers JSON.
    location /api/webhooks/stripe {
        proxy_pass http://academy_nextjs;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_request_buffering off;
    }
}
