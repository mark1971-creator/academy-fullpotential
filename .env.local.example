# Being at Full Potential Academy — environment template
#
# Production (Contabo VPS):  cp .env.example .env
# Local development:         cp .env.example .env.local
#
# Fill in real values from Clerk, Supabase, and Stripe dashboards.
# NEXT_PUBLIC_* variables are inlined at build time — rebuild after changing them.
# Never commit .env or .env.local (they contain secrets).

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Public site URL — no trailing slash (Stripe redirects, webhooks, canonical links)
NEXT_PUBLIC_APP_URL=https://academy.beingatfullpotential.com

# Port for `next start` / PM2 (Nginx proxies to this port)
PORT=3000

# Never use fixture data in production
NEXT_PUBLIC_USE_LOCAL_DATA=false

# -----------------------------------------------------------------------------
# Clerk — https://dashboard.clerk.com (use Live / production instance)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_live_YOUR_SECRET_KEY

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/my-courses
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/my-courses
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/my-courses
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/my-courses

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard → Project Settings → API
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com (Live mode for production)
# Webhook endpoint: https://academy.beingatfullpotential.com/api/webhooks/stripe
# Event: checkout.session.completed
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SIGNING_SECRET

# -----------------------------------------------------------------------------
# Local development only (uncomment in .env.local if testing on localhost)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=http://localhost:3000
