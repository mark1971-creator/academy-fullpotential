{
  "name": "academy-fullpotential",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start -p ${PORT:-3000}",
    "lint": "eslint",
    "deploy:vps": "bash scripts/vps-deploy.sh",
    "seed": "node supabase/seed_course_meta.mjs && node supabase/seed_lessons.mjs --all && node supabase/seed_assignments.mjs --all && node supabase/seed_placeholder_lessons.mjs",
    "seed:legacy-enrollments": "node supabase/seed_legacy_enrollments.mjs",
    "seed:hpcc-assignments": "node supabase/seed_assignments.mjs --slug human-potential-coach-certification",
    "seed:curriculum": "node supabase/seed_lessons.mjs --all && node supabase/seed_assignments.mjs --all",
    "db:apply-assignment-migration": "node scripts/apply-assignment-migration.mjs",
    "optimize:course-images": "node scripts/optimize-course-images.mjs",
    "generate:course-images": "node scripts/generate-course-thumbnails.mjs",
    "generate:og-image": "node scripts/generate-og-image.mjs",
    "export:legacy-enrollees": "node scripts/export-legacy-enrollees-seed.mjs",
    "export:legacy-enrollees:live": "node scripts/export-legacy-enrollees.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.5.1",
    "@radix-ui/react-slot": "^1.2.5",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-player": "^3.4.0",
    "shadcn": "^4.11.0",
    "stripe": "^22.2.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "sharp": "^0.35.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
