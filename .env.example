# Production / VPS — copy to `.env` on the server and fill in real values.
# NEXT_PUBLIC_* variables are inlined at build time; set them before `npm run build`.

# Canonical public URL (no trailing slash) — required for Stripe redirects & webhooks
NEXT_PUBLIC_APP_URL=https://academy.example.com

# Listen port for `next start` / PM2 (Nginx proxies to this port)
PORT=3000

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Optional Clerk path overrides (defaults work if sign-in/sign-up live at these paths)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe — https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Never enable fixture data in production
NEXT_PUBLIC_USE_LOCAL_DATA=false

# Set automatically by PM2 / next start — do not use development mode on the VPS
# NODE_ENV=production
